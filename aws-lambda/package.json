{
  "name": "motco-notification-service-lambda",
  "version": "2.0.0",
  "description": "AWS Lambda migration of the MOTCO Notification Service — serverless architecture with SNS/SQS fan-out, DynamoDB persistence, and dead letter handling",
  "main": "src/functions/eventIngestion/index.js",
  "scripts": {
    "test": "jest --coverage",
    "test:unit": "jest tests/unit --coverage",
    "test:integration": "jest tests/integration --coverage",
    "lint": "eslint 'src/**/*.js' 'tests/**/*.js'"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.400.0",
    "@aws-sdk/client-sns": "^3.400.0",
    "@aws-sdk/lib-dynamodb": "^3.400.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/shared/dynamodb.js",
      "!src/shared/sns.js"
    ]
  }
}
